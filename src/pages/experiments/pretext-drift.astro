---
import ExperimentLayout from "../../layouts/ExperimentLayout.astro";
import { PretextDriftApp } from "../../components/PretextDriftApp.tsx";
---

<ExperimentLayout title="Pretext Drift — artoshi">
  <div class="pretext-drift-root flex min-h-0 flex-1 flex-col">
    <p class="experiment-panel-label" aria-hidden="true">Experiment</p>
    <div class="pretext-drift-canvas flex min-h-0 flex-1 flex-col">
      <PretextDriftApp client:only="react" />
    </div>
  </div>
</ExperimentLayout>

<style>
  .pretext-drift-root {
    position: relative;
    min-height: 0;
  }

  .pretext-drift-canvas {
    flex: 1 1 auto;
    min-height: min(65dvh, 52rem);
  }

  .experiment-panel-label {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    z-index: 20;
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-tertiary);
    pointer-events: none;
  }

  :global(.pretext-drift-controls) {
    display: none;
  }

  :global(.pretext-rail) {
    height: 100%;
  }

  @media (min-width: 1024px) {
    :global(.pretext-drift-controls) {
      display: block;
      min-width: 0;
      border-right: 1px solid var(--color-border-strong);
      background: #050505;
    }

    :global(.pretext-rail) {
      height: 100%;
      padding: 1rem 0.875rem 1.25rem;
    }

    :global(.pretext-rail-inner) {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      height: 100%;
    }

    :global(.pretext-rail-block) {
      position: relative;
    }

    :global(.pretext-rail-block:not(:first-child)::before) {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background-image: radial-gradient(
        circle,
        rgba(255, 255, 255, 0.18) 0 0.9px,
        transparent 1px
      );
      background-size: 10px 1px;
      background-repeat: repeat-x;
      background-position: left top;
      pointer-events: none;
    }

    :global(.pretext-rail-section) {
      margin: 0;
      font-family: var(--font-mono);
      font-size: 0.6rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #c9a84e;
    }

    :global(.pretext-rail-label) {
      font-family: var(--font-sans);
      font-size: 0.78rem;
      color: var(--color-secondary);
      letter-spacing: -0.01em;
    }

    :global(.pretext-rail-value) {
      min-width: 2.5rem;
      text-align: right;
      font-family: var(--font-mono);
      font-size: 0.68rem;
      color: var(--color-primary);
      font-variant-numeric: tabular-nums;
    }

    :global(.pretext-rail-range) {
      width: 100%;
      margin: 0;
      padding: 0;
      height: 10px;
      -webkit-appearance: none;
      appearance: none;
      accent-color: var(--color-accent);
      background: transparent;
    }

    :global(.pretext-rail-range::-webkit-slider-runnable-track) {
      height: 1px;
      background: var(--color-border-strong);
      border-radius: 999px;
    }

    :global(.pretext-rail-range::-webkit-slider-thumb) {
      -webkit-appearance: none;
      appearance: none;
      width: 10px;
      height: 10px;
      border-radius: 999px;
      background: var(--color-primary);
      margin-top: -4px;
      border: 1px solid rgba(0, 0, 0, 0.35);
      box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.06);
    }

    :global(.pretext-rail-range::-moz-range-track) {
      height: 1px;
      background: var(--color-border-strong);
      border: 0;
      border-radius: 999px;
    }

    :global(.pretext-rail-range::-moz-range-thumb) {
      width: 10px;
      height: 10px;
      border-radius: 999px;
      background: var(--color-primary);
      border: 1px solid rgba(0, 0, 0, 0.35);
      box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.06);
    }
  }
</style>
