---
import ExperimentLayout from "../../layouts/ExperimentLayout.astro";
import { PretextDriftApp } from "../../components/PretextDriftApp.tsx";
---

<ExperimentLayout title="Pretext Drift — artoshi">
  <div class="pretext-drift-root flex min-h-0 flex-1 flex-col">
    <p class="experiment-panel-label" aria-hidden="true">Pretext Drift</p>
    <div class="pretext-drift-canvas flex min-h-0 flex-1 flex-col">
      <PretextDriftApp client:only="react" />
    </div>
  </div>
</ExperimentLayout>

<style>
  .pretext-drift-root {
    position: relative;
    min-height: 0;
  }

  .pretext-drift-canvas {
    flex: 1 1 auto;
    min-height: min(65dvh, 52rem);
  }

  .experiment-panel-label {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    z-index: 20;
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-tertiary);
    pointer-events: none;
  }

</style>
