---
// src/pages/index.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import WorkList from "../components/WorkList.astro";
import { work } from "../data/work";
---

<BaseLayout>
  <SiteHeader />
  <main class="flex-1 mx-auto px-6 w-full" style="max-width: var(--container-max)">

    <!-- Bio -->
    <section class="bio-section animate-in" style="animation-delay: 0.25s">
      <p class="bio-desc">
        Artoshi Rei designs and builds digital products. BA in Graphic Communication Design from
        <a href="https://www.arts.ac.uk/colleges/central-saint-martins" target="_blank" rel="noopener noreferrer" class="bio-desc-link">Central Saint Martins</a>.
      </p>
      <p class="bio-current">
        <span class="currently">Currently building:</span>
        {work.filter(w => w.current).map((item, i, arr) => (
          <>
            <a href={item.url} target="_blank" rel="noopener noreferrer" class="current-link"><span class="current-link-text">{item.title}</span><svg class="current-link-arrow" viewBox="0 0 6 6" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M1.25 0.75L5.25 0.75L5.25 4.75" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/><path d="M5.25 0.75L0.75 5.25" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/></svg></a>{i < arr.length - 1 && <span class="currently"> and</span>}
          </>
        ))}.
      </p>
    </section>

    <!-- Work index -->
    <section class="work-section animate-in" style="animation-delay: 0.45s">
      <WorkList items={work} />
    </section>

  </main>
  <SiteFooter />
</BaseLayout>

<style>
  /* ─── Bio section ──────────────────────────────── */
  .bio-section {
    padding: 3.5rem 0 0;
    padding-left: calc(3.5rem + 0.75rem);
  }

  /* Bio description — muted like baytas tertiary (#71717b) */
  .bio-desc {
    font-size: 0.875rem;
    color: var(--color-tertiary);
    line-height: 1.7;
    max-width: 24rem;
    margin-bottom: 0.5rem;
  }

  .bio-desc-link {
    color: var(--color-tertiary);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--color-border-strong);
    transition: text-decoration-color 0.2s ease, color 0.2s ease;
  }

  .bio-desc-link:hover {
    color: var(--color-secondary);
    text-decoration-color: var(--color-secondary);
  }

  /* Currently building line — secondary color for connective text */
  .bio-current {
    font-size: 0.875rem;
    color: var(--color-secondary);
    line-height: 1.7;
    max-width: 24rem;
  }

  .currently {
    color: var(--color-secondary);
  }

  /* Project links — brightest, like baytas primary (#fafafa) */
  .current-link {
    display: inline-flex;
    align-items: center;
    color: var(--color-primary);
    text-decoration: none;
    padding: 0 0;
    border-radius: 2px;
    transition: padding 0.5s ease, background-color 0.5s ease, filter 0.5s ease;
  }

  .current-link-arrow {
    width: 0;
    height: 0.55em;
    margin-left: 0;
    opacity: 0;
    transition: width 0.2s ease, margin-left 0.2s ease, opacity 0.2s ease;
  }

  @media (pointer: fine) {
    .current-link:hover {
      background-color: #000;
      padding: 0 0.25rem;
      filter: invert(1);
      transition: padding 0.15s ease, background-color 0.15s ease, filter 0.15s ease;
    }

    .current-link:hover .current-link-arrow {
      width: 0.55em;
      margin-left: 0.2em;
      opacity: 1;
    }
  }

  /* ─── Work section ─────────────────────────────── */
  .work-section {
    padding-top: 2rem;
    padding-bottom: 6rem;
  }

</style>
