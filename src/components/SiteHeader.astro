---
// src/components/SiteHeader.astro
---

<header
  class="animate-in-fade sticky top-0 z-50 header-bar"
  style="animation-delay: 0s"
>
  <a href="/" class="header-inner header-home" aria-label="Home">
    <svg
      id="mascot-icon"
      class="header-logo"
      viewBox="0 0 649 512"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <defs>
        <clipPath id="body-clip">
          <path d="M562.831 269.466C613.091 251.273 649 203.129 649 146.602C649 74.4521 590.502 15.9636 518.341 15.9636C481.989 15.9636 449.102 30.8084 425.419 54.7668C403.962 21.7985 366.776 0 324.502 0C282.224 0 245.042 21.7985 223.58 54.7668C199.898 30.8084 167.011 15.9636 130.659 15.9636C58.4976 15.9636 0 74.4521 0 146.602C0 204.876 38.1635 254.242 90.8688 271.071C54.4352 294.25 30.2622 334.981 30.2622 381.361C30.2622 453.511 88.7598 512 160.921 512C192.767 512 221.954 500.61 244.625 481.673C265.871 500.537 293.844 512 324.502 512C356.882 512 386.271 499.212 407.9 478.416C431.057 499.294 461.724 512 495.36 512C567.521 512 626.019 453.511 626.019 381.361C626.019 333.897 600.701 292.344 562.831 269.466Z" />
        </clipPath>
      </defs>
      <path
        d="M562.831 269.466C613.091 251.273 649 203.129 649 146.602C649 74.4521 590.502 15.9636 518.341 15.9636C481.989 15.9636 449.102 30.8084 425.419 54.7668C403.962 21.7985 366.776 0 324.502 0C282.224 0 245.042 21.7985 223.58 54.7668C199.898 30.8084 167.011 15.9636 130.659 15.9636C58.4976 15.9636 0 74.4521 0 146.602C0 204.876 38.1635 254.242 90.8688 271.071C54.4352 294.25 30.2622 334.981 30.2622 381.361C30.2622 453.511 88.7598 512 160.921 512C192.767 512 221.954 500.61 244.625 481.673C265.871 500.537 293.844 512 324.502 512C356.882 512 386.271 499.212 407.9 478.416C431.057 499.294 461.724 512 495.36 512C567.521 512 626.019 453.511 626.019 381.361C626.019 333.897 600.701 292.344 562.831 269.466Z"
        fill="#BABABA"
      />
      <g clip-path="url(#body-clip)">
        <g id="mascot-eyes-anchor" transform="translate(235, 124)">
          <g id="mascot-eyes-travel">
            <rect id="mascot-eye-left" fill="#010308" />
            <rect id="mascot-eye-right" fill="#010308" />
          </g>
        </g>
      </g>
    </svg>
    <span class="header-name" id="header-scramble" data-final="ARTOSHI">ARTOSHI</span>
  </a>
</header>

<style>
  .header-bar {
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border-strong);
  }

  .header-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 1rem 1.5rem 1rem calc(1.5rem + 3.5rem + 0.75rem);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 1.7rem;
    font-weight: 600;
    line-height: 1;
  }

  .header-home {
    text-decoration: none;
    color: inherit;
  }

  .header-logo {
    display: block;
    overflow: visible;
    height: 1cap;
    width: auto;
    flex-shrink: 0;
  }

  .header-name {
    color: var(--color-primary);
    letter-spacing: -0.01em;
  }
</style>

<script>
  // ─── Scramble animation ──────────────────────────────
  const POOL = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';
  const TICK_MS = 35;

  function scramble(el: HTMLElement) {
    const final = el.dataset.final ?? el.textContent ?? '';
    let resolved = 0;

    const interval = setInterval(() => {
      const chars = final.split('').map((ch, i) => {
        if (i < resolved) return ch;
        return POOL[Math.floor(Math.random() * POOL.length)];
      });
      el.textContent = chars.join('');

      resolved++;
      if (resolved >= final.length) {
        el.textContent = final;
        clearInterval(interval);
      }
    }, TICK_MS);
  }

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReduced) {
    const el = document.getElementById('header-scramble') as HTMLElement | null;
    if (el) scramble(el);
  }

  // ─── Mascot eye animation ────────────────────────────
  const MAX_CURSOR_PULL = 42;
  const SPRING_SPEED = 0.24;
  const EYE_RETURN_DELAY_MS = 1300;
  const BLINK_INTERVAL_MIN = 2600;
  const BLINK_INTERVAL_MAX = 5400;
  const BLINK_CLOSE_MS = 78;
  const BLINK_OPEN_MS = 120;

  const EYE_GEOMETRY = [
    { cx: 38.92463, cy: 131.08272 },
    { cx: 127.4235, cy: 131.08273 },
  ];
  const EYE_WIDTH = 46;
  const EYE_HEIGHT = 198;
  const EYE_GROUP_CENTER = {
    x: (EYE_GEOMETRY[0].cx + EYE_GEOMETRY[1].cx) / 2,
    y: (EYE_GEOMETRY[0].cy + EYE_GEOMETRY[1].cy) / 2,
  };
  const EYES_ANCHOR = { x: 235, y: 124 };
  const EYE_CENTER_VIEWBOX = {
    x: EYES_ANCHOR.x + EYE_GROUP_CENTER.x,
    y: EYES_ANCHOR.y + EYE_GROUP_CENTER.y,
  };
  const EYE_OFFSETS = EYE_GEOMETRY.map((eye) => ({
    x: eye.cx - EYE_GROUP_CENTER.x,
    y: eye.cy - EYE_GROUP_CENTER.y,
  }));

  function clampVector(px: number, py: number, max: number): { x: number; y: number } {
    const mag = Math.hypot(px, py);
    if (mag === 0 || mag <= max) return { x: px, y: py };
    const s = max / mag;
    return { x: px * s, y: py * s };
  }

  function easeOutCubic(t: number): number {
    return 1 - Math.pow(1 - t, 3);
  }

  function easeInOutCubic(t: number): number {
    return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
  }

  const svg = document.getElementById('mascot-icon') as SVGSVGElement | null;
  const travelGroup = document.getElementById('mascot-eyes-travel') as SVGGElement | null;
  const eyeLeft = document.getElementById('mascot-eye-left') as SVGRectElement | null;
  const eyeRight = document.getElementById('mascot-eye-right') as SVGRectElement | null;

  if (svg && travelGroup && eyeLeft && eyeRight && !prefersReduced) {
    const target = { x: 0, y: 0 };
    const offset = { x: 0, y: 0 };
    let blinkValue = 0;
    let blinkPhase: 'idle' | 'closing' | 'opening' = 'idle';
    let idleTimeout: number | null = null;
    let blinkTimeout: number | null = null;
    let blinkRaf: number | null = null;

    // ─── Pointer tracking ─────────────────────────
    function pointerToSvg(event: PointerEvent): { x: number; y: number } | null {
      const ctm = svg!.getScreenCTM();
      if (!ctm) return null;
      const pt = svg!.createSVGPoint();
      pt.x = event.clientX;
      pt.y = event.clientY;
      const t = pt.matrixTransform(ctm.inverse());
      return { x: t.x, y: t.y };
    }

    function resetTarget() {
      target.x = 0;
      target.y = 0;
    }

    function onPointerMove(event: PointerEvent) {
      const pt = pointerToSvg(event);
      if (!pt) return;
      const clamped = clampVector(pt.x - EYE_CENTER_VIEWBOX.x, pt.y - EYE_CENTER_VIEWBOX.y, MAX_CURSOR_PULL);
      target.x = clamped.x;
      target.y = clamped.y;
      if (idleTimeout) window.clearTimeout(idleTimeout);
      idleTimeout = window.setTimeout(resetTarget, EYE_RETURN_DELAY_MS);
    }

    function onPointerLeave() {
      resetTarget();
      if (idleTimeout) { window.clearTimeout(idleTimeout); idleTimeout = null; }
    }

    window.addEventListener('pointermove', onPointerMove);
    window.addEventListener('pointerleave', onPointerLeave);
    window.addEventListener('blur', onPointerLeave);

    // ─── Blink system ─────────────────────────────
    function animateBlink(phase: 'closing' | 'opening', start: number) {
      const duration = phase === 'closing' ? BLINK_CLOSE_MS : BLINK_OPEN_MS;

      const tick = (time: number) => {
        const elapsed = time - start;
        const progress = Math.min(Math.max(elapsed / duration, 0), 1);
        const eased = phase === 'closing' ? easeOutCubic(progress) : easeInOutCubic(progress);
        blinkValue = phase === 'closing' ? eased : 1 - eased;

        if (progress < 1) {
          blinkRaf = requestAnimationFrame(tick);
          return;
        }

        if (phase === 'closing') {
          blinkPhase = 'opening';
          blinkRaf = requestAnimationFrame((t) => animateBlink('opening', t));
          return;
        }

        blinkPhase = 'idle';
        blinkRaf = null;
        scheduleBlink();
      };

      blinkRaf = requestAnimationFrame(tick);
    }

    function launchBlink() {
      if (blinkPhase !== 'idle') return;
      blinkPhase = 'closing';
      animateBlink('closing', performance.now());
    }

    function scheduleBlink() {
      const delay = BLINK_INTERVAL_MIN + Math.random() * (BLINK_INTERVAL_MAX - BLINK_INTERVAL_MIN);
      blinkTimeout = window.setTimeout(launchBlink, delay);
    }

    scheduleBlink();

    // ─── Animation loop ───────────────────────────
    let lastTime = performance.now();

    function step(time: number) {
      const delta = Math.min((time - lastTime) / 16.67, 1.8);
      lastTime = time;

      // Spring interpolation
      const spring = SPRING_SPEED * delta;
      offset.x += (target.x - offset.x) * spring;
      offset.y += (target.y - offset.y) * spring;

      // Calculate eye dimensions
      const magnitude = Math.min(Math.hypot(offset.x, offset.y) / MAX_CURSOR_PULL, 1);
      const travel = { x: offset.x * 1.2, y: offset.y * 0.8 };
      const normalizedHorizontal = Math.max(Math.min(offset.x / MAX_CURSOR_PULL, 1), -1);
      const spacingFactor = 1 - Math.min(Math.abs(normalizedHorizontal) * 0.22, 0.26);

      const blinkCompression = 1 - 0.92 * blinkValue;
      const dynamicHeight = EYE_HEIGHT * (1 - 0.12 * magnitude) * blinkCompression;
      const dynamicWidth = EYE_WIDTH * (1 + 0.08 * magnitude);

      // Update travel group transform
      travelGroup!.setAttribute('transform', `translate(${travel.x}, ${travel.y})`);

      // Update each eye
      const eyes = [eyeLeft!, eyeRight!];
      for (let i = 0; i < 2; i++) {
        const horizontalBias = offset.x * 0.06 * (i === 0 ? 1 : -1);
        const verticalBias = offset.y * 0.06;
        const cx = EYE_GROUP_CENTER.x + EYE_OFFSETS[i].x * spacingFactor;
        const cy = EYE_GROUP_CENTER.y + EYE_OFFSETS[i].y;
        const x = cx - dynamicWidth / 2 + horizontalBias;
        const y = cy - dynamicHeight / 2 + verticalBias;

        eyes[i].setAttribute('x', String(x));
        eyes[i].setAttribute('y', String(y));
        eyes[i].setAttribute('width', String(dynamicWidth));
        eyes[i].setAttribute('height', String(dynamicHeight));
        eyes[i].setAttribute('rx', String(dynamicWidth / 2));
      }

      requestAnimationFrame(step);
    }

    requestAnimationFrame(step);
  }

</script>
