---
// src/components/SiteFooter.astro

const year = new Date().getFullYear();
const socials = [
  { label: "X", href: "https://x.com/artoshiverse" },
  { label: "IG", href: "https://instagram.com/artoshiverse" },
  { label: "GH", href: "https://github.com/artoshirei" },
];
---

<footer
  class="animate-in mt-auto"
  style="animation-delay: 0.8s"
>
  <div class="footer-inner">
    <p class="footer-meta">&copy; {year} ARTOSHI</p>
    <nav class="footer-nav" aria-label="Social links">
      {socials.map(({ label, href }) => (
        <a
          href={href}
          class="footer-link"
          target="_blank"
          rel="noopener noreferrer"
        >
          {label}
        </a>
      ))}
    </nav>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--color-border-strong);
    background: var(--color-bg);
  }

  .footer-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 1rem calc(1.5rem + 0.75rem) 1rem calc(1.5rem + 3.5rem + 0.75rem);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-meta {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-primary);
    letter-spacing: 0.04em;
  }

  .footer-nav {
    display: flex;
    gap: 1.25rem;
  }

  .footer-link {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 500;
    color: var(--color-primary);
    text-decoration: none;
    letter-spacing: 0.04em;
    transition: color 0.15s ease;
  }

  .footer-link:hover {
    color: var(--color-accent);
  }
</style>
