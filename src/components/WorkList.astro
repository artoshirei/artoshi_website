---
// src/components/WorkList.astro
import type { WorkItem } from "../data/work";

interface Props {
  items: WorkItem[];
}
const { items } = Astro.props;

const sorted = [...items].sort((a, b) => b.year - a.year);

const delay = (i: number) =>
  (0.5 + i * 0.08).toFixed(3);

const isExternal = (url: string) => url.startsWith("http");

// First item of each year group gets the year label
const showYear = sorted.map((item, i) =>
  i === 0 || item.year !== sorted[i - 1].year
);
---

<ul class="work-list">
  {sorted.map((item, i) => (
    <li
      class="work-item animate-in"
      style={`animation-delay: ${delay(i)}s`}
    >
      {showYear[i] && (
        <time class="work-year">{item.year}</time>
      )}
      {item.url ? (
        <a
          href={item.url}
          class="work-row"
          target={isExternal(item.url) ? "_blank" : "_self"}
          rel={isExternal(item.url) ? "noopener noreferrer" : undefined}
        >
          <span class="work-title">{item.title}</span>
          {item.description && <span class="work-desc">{item.description}</span>}
          <span class="work-right">
            <span class="work-tag">{item.categories[0]}</span>
            <span class="work-arrow" aria-hidden="true">
              {isExternal(item.url) ? (
                <svg focusable="false" fill="currentColor" width="10" height="10" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
                  <path d="M10 6L10 8 22.59 8 6 24.59 7.41 26 24 9.41 24 22 26 22 26 6 10 6z" />
                </svg>
              ) : (
                <svg focusable="false" fill="currentColor" width="10" height="10" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="16" cy="16" r="8" />
                </svg>
              )}
            </span>
          </span>
        </a>
      ) : (
        <div class="work-row">
          <span class="work-title">{item.title}</span>
          {item.description && <span class="work-desc">{item.description}</span>}
          <span class="work-right">
            <span class="work-tag">{item.categories[0]}</span>
          </span>
        </div>
      )}
    </li>
  ))}
</ul>

<style>
  .work-list {
    list-style: none;
    margin: 0;
    padding: 0;
    padding-left: 3.5rem;
  }

  /* ─── Each item ──────────────────────────────────── */
  .work-item {
    position: relative;
    border-top: 1px solid var(--color-border-strong);
  }

  /* Hover: dim siblings (pointer devices only) */
  @media (pointer: fine) {
    .work-list:has(.work-row:hover) .work-row:not(:hover) {
      opacity: 0.4;
    }

    .work-row:hover {
      opacity: 1 !important;
      color: var(--color-primary);
      background-color: rgba(255, 255, 255, 0.03);
      transition-duration: 0ms;
    }
  }

  /* ─── Year label: pinned to the left ─────────────── */
  .work-year {
    position: absolute;
    left: -3.5rem;
    top: 0.375rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-tertiary);
    font-variant-numeric: tabular-nums;
    pointer-events: none;
    user-select: none;
  }

  /* ─── Row layout ─────────────────────────────────── */
  .work-row {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    gap: 0.1rem 1rem;
    padding: 0.375rem 0.75rem;
    text-decoration: none;
    color: var(--color-secondary);
    cursor: default;
    transition: opacity 1s cubic-bezier(0.4, 0, 0.2, 1),
                background-color 1s cubic-bezier(0.4, 0, 0.2, 1),
                color 1s cubic-bezier(0.4, 0, 0.2, 1);
  }

  a.work-row {
    cursor: pointer;
  }

  /* ─── Title ──────────────────────────────────────── */
  .work-title {
    grid-column: 1;
    grid-row: 1;
    font-size: 0.875rem;
    color: inherit;
    font-weight: 500;
    white-space: nowrap;
  }

  .work-desc {
    grid-column: 1 / -1;
    grid-row: 2;
    font-size: 0.875rem;
    color: inherit;
    font-weight: 400;
    opacity: 0.6;
  }

  /* ─── Right group ────────────────────────────────── */
  .work-right {
    grid-column: 2;
    grid-row: 1;
    display: flex;
    align-items: center;
  }

  .work-tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: inherit;
    white-space: nowrap;
    letter-spacing: 0.04em;
  }

  /* ─── Arrow indicator ────────────────────────────── */
  .work-arrow {
    flex-shrink: 0;
    align-self: center;
    color: var(--color-primary);
    opacity: 0;
    width: 0;
    margin-left: 0;
    overflow: hidden;
    filter: blur(2px);
    transition: opacity 250ms cubic-bezier(0, 0, 0.58, 1),
                width 1s cubic-bezier(0, 0, 0.58, 1),
                margin-left 1s cubic-bezier(0, 0, 0.58, 1),
                filter 250ms cubic-bezier(0, 0, 0.58, 1);
  }

  .work-row:hover .work-arrow {
    opacity: 1;
    width: 10px;
    margin-left: 6px;
    filter: blur(0);
    transition-duration: 150ms;
  }

  @media (prefers-reduced-motion: reduce) {
    .work-row,
    .work-arrow {
      transition: none;
    }
  }

  /* ─── Mobile ────────────────────────────────────── */
  @media (max-width: 640px) {
    .work-list {
      padding-left: 3rem;
    }

    .work-year {
      left: -3rem;
    }

    .work-row {
      padding: 0.5rem 0.75rem;
    }

    .work-arrow {
      display: none;
    }
  }
</style>
