---
// src/layouts/ExperimentLayout.astro
import BaseLayout from "./BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

interface Props {
  title?: string;
}
const { title = "artoshi — design + development" } = Astro.props;
---

<BaseLayout title={title}>
  <SiteHeader />
  <main class="experiment-main flex-1 min-h-0 flex flex-col w-full">
    <slot />
  </main>
  <SiteFooter />
</BaseLayout>

<style>
  .experiment-main {
    flex: 1 1 auto;
    min-height: 0;
  }
</style>
